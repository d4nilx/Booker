<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Booker"
             xmlns:converters="clr-namespace:Booker.Converters"
             x:Class="Booker.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters referenced by all pages via StaticResource -->
            <converters:InvertedBoolConverter x:Key="InvertedBool" />
            <converters:StringToBoolConverter x:Key="StringToBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
